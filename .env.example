# Copy this file to .env and fill in your values
# cp .env.example .env

VITE_PUBLIC_BUILDER_KEY=your_builder_key_here
PING_MESSAGE="ping pong"

# ── WhatsApp Evolution API ────────────────────────────────────────────────────
EVOLUTION_API_URL=https://your-evolution-api-url/
EVOLUTION_API_KEY=your_evolution_api_key
EVOLUTION_INSTANCE=Evolution2

# ── Instagram (instagrapi) ────────────────────────────────────────────────────
INSTAGRAPI_API_URL=https://your-cloudflare-tunnel-url
INSTAGRAPI_API_KEY=your_instagrapi_key
INSTAGRAM_USERNAME=your_instagram_email
INSTAGRAM_PASSWORD=your_instagram_password

# ── OpenRouter (AI Parser) ────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-your_key_here
OPENROUTER_MODEL=openai/gpt-oss-120b:free
APP_URL=https://openrouter.ai/
